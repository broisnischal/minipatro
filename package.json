{
  "name": "minipatro",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply minipatro --local",
    "db:migrate:remote": "wrangler d1 migrations apply minipatro --remote",
    "db:studio": "drizzle-kit studio",
    "prepare:calendar:data": "bun run scripts/prepare-nepali-calendar-data.ts",
    "seed:calendar:sql": "bun run scripts/seed-nepali-calendar.ts",
    "seed:calendar:local": "bun run prepare:calendar:data && bun run seed:calendar:sql && wrangler d1 execute minipatro --local --file drizzle/seed/calendar-seed.sql",
    "seed:calendar:remote": "bun run prepare:calendar:data && bun run seed:calendar:sql && wrangler d1 execute minipatro --remote --file drizzle/seed/calendar-seed.sql",
    "deploy": "npm run build && wrangler deploy",
    "dev": "react-router dev",
    "postinstall": "npm run cf-typegen",
    "preview": "npm run build && vite preview",
    "taze": "taze -r",
    "typecheck": "npm run cf-typegen && react-router typegen && tsc -b"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "isbot": "^5.1.36",
    "lucide-react": "^1.7.0",
    "nepali-date-converter": "^3.4.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.13.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.1",
    "@react-router/dev": "7.13.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "shadcn": "^4.1.2",
    "tailwindcss": "^4.2.2",
    "taze": "^19.11.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.75.0"
  }
}
